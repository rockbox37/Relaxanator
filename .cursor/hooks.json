{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "deft hook:dispatch --host cursor --event session.start",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "deft hook:dispatch --host cursor --event tool.before",
        "matcher": "Edit|Write|WriteFile|CreateFile|MultiEdit|NotebookEdit|StrReplace|SearchReplace|Delete|DeleteFile|ApplyPatch|apply_patch",
        "failClosed": false,
        "timeout": 5
      },
      {
        "command": "deft hook:dispatch --host cursor --event tool.before",
        "matcher": "Task|SubagentStart|spawn_subagent|start_agent|CreateAgent",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "preCompact": [
      {
        "command": "deft hook:dispatch --host cursor --event session.compact",
        "timeout": 5
      }
    ]
  }
}
